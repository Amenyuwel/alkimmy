{
	"$schema": "https://biomejs.dev/schemas/2.4.10/schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"files": {
		"ignoreUnknown": false,
		"includes": ["src/**/*", "src/**/*.{ts,tsx,js,jsx}"]
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"lineWidth": 100
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"a11y": {
				"noDistractingElements": "error",
				"useAltText": "error",
				"useAnchorContent": "error",
				"useButtonType": "error",
				"useHtmlLang": "error",
				"useIframeTitle": "error"
			},
			"complexity": {
				"noExtraBooleanCast": "error",
				"noForEach": "warn",
				"useLiteralKeys": "error"
			},
			"correctness": {
				"noUnusedVariables": "error",
				"useExhaustiveDependencies": "warn",
				"useHookAtTopLevel": "error"
			},
			"style": {
				"noNonNullAssertion": "error",
				"useConst": "error",
				"useNamingConvention": "warn",
				"useSelfClosingElements": "error"
			},
			"suspicious": {
				"noExplicitAny": "error",
				"noImplicitAnyLet": "error",
				"useAwait": "error"
			}
		}
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "double",
			"trailingCommas": "all"
		}
	},
	"assist": {
		"enabled": true,
		"actions": {
			"source": {
				"organizeImports": "on"
			}
		}
	}
}
